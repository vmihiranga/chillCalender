# Vercel Postgres (Neon) - auto-injected by Vercel when you add a Postgres DB integration
# For local development, copy from your Vercel project settings → Storage → your DB → .env.local tab
POSTGRES_PRISMA_URL="postgresql://user:pass@host/dbname?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgresql://user:pass@host/dbname"
